#!/bin/bash

SESSION_NAME="bot"
VENV_PYTHON="venv/bin/python"

# Check if virtual environment exists, create if not
if [ ! -d "venv" ]; then
    echo "Virtual environment not found. Creating one..."
    python3 -m venv venv || exit 1
fi

# Start tmux session or attach if already running
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    echo "Session $SESSION_NAME already exists. Attaching..."
    tmux attach -t "$SESSION_NAME"
else
    echo "Starting new tmux session: $SESSION_NAME"

    BOT_ARGS=""
    if [ "$#" -gt 0 ]; then
        printf -v BOT_ARGS " %q" "$@"
    fi
    START_COMMAND="$VENV_PYTHON -m pip install --upgrade -r requirements.txt && $VENV_PYTHON src/main.py$BOT_ARGS"

    # Start attached so first-run configuration prompts have a live terminal.
    # Keep the shell open after failure so the error remains visible.
    tmux new-session -s "$SESSION_NAME" \
        "$START_COMMAND; status=\$?; echo; echo \"Bot bootstrap exited with status \$status\"; exec bash"
fi
