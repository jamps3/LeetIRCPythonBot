#!/usr/bin/env python3
"""
Update LeetIRCPythonBot dependencies with uv.

The dependency source of truth is pyproject.toml. This script refreshes uv.lock
to the latest compatible package versions, syncs the local environment, and
prints the resulting dependency changes.
"""

import shutil
import subprocess
import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).parent.resolve()


def run_command(args: list[str], description: str) -> bool:
    """Run a command in the project root and stream output."""
    print(f"\n{'=' * 60}")
    print(f"Running: {description}")
    print(f"{'=' * 60}")
    result = subprocess.run(args, cwd=PROJECT_ROOT, check=False)  # noqa: S603
    if result.returncode != 0:
        print(f"Command failed with exit code {result.returncode}")
        return False
    return True


def main() -> int:
    print("LeetIRCPythonBot uv dependency updater")
    print(f"Project root: {PROJECT_ROOT}")

    uv = shutil.which("uv")
    if uv is None:
        print("uv is required. Install it from:")
        print("https://docs.astral.sh/uv/getting-started/installation/")
        return 1
    git = shutil.which("git")

    steps = [
        ([uv, "lock", "--upgrade"], "Resolve latest compatible dependencies"),
        ([uv, "sync", "--dev"], "Sync local environment"),
        ([uv, "run", "python", "-m", "pytest", "-q"], "Run tests"),
    ]
    for args, description in steps:
        if not run_command(args, description):
            return 1

    if git is None:
        print("\nGit not found; skipping dependency diff.")
        return 0

    result = subprocess.run(  # noqa: S603
        [git, "diff", "--", "pyproject.toml", "uv.lock"],
        cwd=PROJECT_ROOT,
        check=False,
        capture_output=True,
        text=True,
    )
    if result.stdout:
        print("\nDependency file changes:")
        print(result.stdout[:4000])
    else:
        print("\nNo dependency file changes detected.")

    print("\nUpdate complete.")
    print("Common commands:")
    print("  uv run python src/main.py")
    print("  uv run pytest -v --tb=short -n auto")
    print("  uv run ruff check .")
    return 0


if __name__ == "__main__":
    sys.exit(main())
