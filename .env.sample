# Sample .env file for LeetIRCPythonBot. Copy this file to .env and fill in the required values.
# API Keys
# Replace these placeholders with your actual API keys
WEATHER_API_KEY = "your_openweathermap_api_key_here"
WEATHER_FORECAST_API_KEY = "your_meteosource_api_key_here"
ELECTRICITY_API_KEY = "your_electricity_api_key_here"
OPENAI_API_KEY = "your_openai_api_key_here"
OPENAI_MODEL = "gpt-5.4"  # Model for GPT service (gpt-5.4, gpt-4o, gpt-4o-mini, gpt-5-mini, etc.)
YOUTUBE_API_KEY = "your_youtube_api_key_here"
EUROJACKPOT_API_KEY = "your_eurojackpot_api_key_here"
X_BEARER_TOKEN = "your_x_bearer_token_here"

# Bot Configuration Settings
BOT_NAME=LeetIRCBot
LOG_LEVEL=INFO
ADMIN_PASSWORD=abc123xy
RECONNECT_DELAY=60  # Seconds to wait before reconnecting to server
QUIT_MESSAGE=🍺 Nähdään! 🍺  # Quit message
USE_NOTICES=true  # Send responses as IRC NOTICE instead of PRIVMSG
TAMAGOTCHI_ENABLED=true  # Enable tamagotchi responses to trigger words
420_ENABLED=true  # Enable 4:20 time announcements
AUTO_CONNECT=true  # Automatically connect to servers on startup

# Data and History Settings
GPT_HISTORY_LIMIT=100  # Maximum number of messages to keep in GPT conversation history
HISTORY_FILE=data/conversation_history.json  # Path to conversation history file
STATE_FILE=data/state.json  # Path to bot state file
WORDS_FILE=data/general_words.json  # Path to general words tracking file
EKAVIKA_FILE=data/ekavika.json  # Path to ekavika word tracking file
SUBSCRIBERS_FILE=data/subscribers.json  # Path to subscribers list

# Title Fetching Blacklist Settings
TITLE_BLACKLIST_DOMAINS="youtube.com,youtu.be,facebook.com,fb.com,x.com,twitter.com,instagram.com,tiktok.com,discord.com,reddit.com,imgur.com"
TITLE_BLACKLIST_EXTENSIONS=".jpg,.jpeg,.png,.gif,.mp4,.webm,.pdf,.zip,.rar,.mp3,.wav,.flac"
TITLE_BANNED_TEXTS="Bevor Sie zu Google Maps weitergehen;Just a moment...;403 Forbidden;404 Not Found;Access Denied;Ennen kuin jatkat Google Mapsiin;Twitch;Bevor Sie zur Google Suche weitergehen"

# Channel Restrictions
OPS_ALLOWED_CHANNELS=""  # Comma-separated channels where !ops command is allowed

# Optional Settings
# LOG_ROTATION_SIZE=10485760  # Max log file size in bytes (default: 10MB)
# LOG_ROTATION_COUNT=5  # Maximum number of rotated log files to keep
# LOG_ROTATION_INTERVAL=  # Time-based rotation: minute, hour, day, week, month, year (optional)
# LOG_ROTATION_TIME=00:00  # Time of day for daily/weekly/monthly rotation (HH:MM format)
# FORCE_CONSOLE=false  # Force console mode instead of IRC (true/false)
# IRC_ENCODING=utf-8  # Character encoding for IRC connections

# Server Configurations
# Format: SERVERx_HOST, SERVERx_PORT, SERVERx_CHANNELS, SERVERx_KEYS
# Where x is a unique identifier for each server

# Server 1
SERVER1_HOST=irc.atw-inter.net
SERVER1_PORT=6697
SERVER1_CHANNELS=#LeetIRCPythonBot
SERVER1_KEYS=
SERVER1_TLS=true
SERVER1_ALLOW_INSECURE_TLS=true

# Server 2 (example - uncomment and configure as needed)
#SERVER2_HOST=irc.libera.chat
#SERVER2_PORT=6667
#SERVER2_CHANNELS=#python,#linux
#SERVER2_KEYS=
#SERVER2_TLS=false
#SERVER2_ALLOW_INSECURE_TLS=false

# Add more servers as needed following the same pattern
#SERVER3_HOST=...
#SERVER3_PORT=...
#SERVER3_CHANNELS=...
#SERVER3_KEYS=...
#SERVER3_TLS=...
#SERVER3_ALLOW_INSECURE_TLS=...