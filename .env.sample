# Sample .env file for LeetIRCPythonBot. Copy this file to .env and fill in the required values.
# API Keys
# Replace these placeholders with your actual API keys
WEATHER_API_KEY = "your_openweathermap_api_key_here"
WEATHER_FORECAST_API_KEY = "your_meteosource_api_key_here"
ELECTRICITY_API_KEY = "your_electricity_api_key_here"
OPENAI_API_KEY = "your_openai_api_key_here"
YOUTUBE_API_KEY = "your_youtube_api_key_here"
EUROJACKPOT_API_KEY = "your_eurojackpot_api_key_here"
X_BEARER_TOKEN = "your_x_bearer_token_here"

# Bot Configuration Settings
BOT_NAME=LeetIRCBot
LOG_LEVEL=INFO
ADMIN_PASSWORD=abc123xy

# Server Configurations
# Format: SERVERx_HOST, SERVERx_PORT, SERVERx_CHANNELS, SERVERx_KEYS
# Where x is a unique identifier for each server

# Server 1
SERVER1_HOST=irc.atw-inter.net
SERVER1_PORT=6697
SERVER1_CHANNELS=#LeetIRCPythonBot
SERVER1_KEYS=
SERVER1_TLS=true
SERVER1_ALLOW_INSECURE_TLS=true

# Server 2 (example - uncomment and configure as needed)
#SERVER2_HOST=irc.libera.chat
#SERVER2_PORT=6667
#SERVER2_CHANNELS=#python,#linux
#SERVER2_KEYS=
#SERVER2_TLS=false
#SERVER2_ALLOW_INSECURE_TLS=false

# Add more servers as needed following the same pattern
#SERVER3_HOST=...
#SERVER3_PORT=...
#SERVER3_CHANNELS=...
#SERVER3_KEYS=...
#SERVER3_TLS=...
#SERVER3_ALLOW_INSECURE_TLS=...